reads saved NetCDFs + epoch CSVs, no retraining.        ║\n# ╚══════════════════════════════════════════════════════════════════════╝\nEVAL_YEARS = range(TEST_START, TEST_END + 1)   # TRAIN_* for training period\nEVAL_NC    = MLP_TEST_NC                        # MLP_TRAIN_NC for training period\n\n# ── metric helpers ───────────────────────────────────────────────────\ndef _rmse(o, p): return float(np.sqrt(np.mean((o - p) ** 2)))\ndef _mae (o, p): return float(np.mean(np.abs(o - p)))\ndef _mse (o, p): return float(np.mean((o - p) ** 2))\ndef _r2  (o, p):\n    ss = np.sum((o - o.mean()) ** 2)\n    return float(1 - np.sum((o - p) ** 2) / ss) if ss > 0 else np.nan\ndef _corr(o, p):\n    if o.size < 2 or np.std(o) == 0 or np.std(p) == 0: return np.nan\n    return float(np.corrcoef(o, p)[0, 1])\ndef _kge(o, p):\n    if o.size < 2: return np.nan\n    r = _corr(o, p)\n    a = np.std(p) / np.std(o) if np.std(o) > 0 else np.nan      # variability ratio\n    b = np.mean(p) / np.mean(o) if np.mean(o) != 0 else np.nan  # bias ratio\n    if np.isnan(r) or np.isnan(a) or np.isnan(b): return np.nan\n    return float(1 - np.sqrt((r - 1) ** 2 + (a - 1) ** 2 + (b - 1) ** 2))\n\n# ── gather every stage's daily fields over the region, by month ──────\ndef _collect(years, mlp_nc):\n    dsm = xr.open_dataset(mlp_nc)\n    daily = {s: {\"o\": [], \"p\": []} for s in [\"raw\", \"bias\", \"mlp\"]}          # pooled daily\n    jjas  = {s: {\"o\": [], \"p\": []} for s in [\"raw\", \"bias\", \"mlp\"]}          # Jun–Sep daily\n    mtot  = {s: {\"o\": [], \"p\": []} for s in [\"raw\", \"bias\", \"mlp\"]}          # monthly totals\n    # accumulators for per-cell climatology (sum over all days) and per-month region means\n    clim_sum = {s: np.zeros(n5) for s in [\"raw\", \"bias\", \"mlp\", \"obs\"]}\n    clim_cnt = 0\n    mon_mean = {s: np.zeros(12) for s in [\"raw\", \"bias\", \"mlp\", \"obs\"]}\n    mon_cnt  = np.zeros(12)\n    for month in range(1, 13):\n        g1, doy, dates = load_month(\"gcm1\", years, month)\n        obs5, _, _     = load_month(\"chr5\", years, month)\n        if g1 is None or obs5 is None: continue\n        mk = f\"m{month:02d}\"\n        raw  = bc1_to_005(g1)                                              # (days, n5)\n        bias = bc1_to_005(qm_apply(g1, qm1[f\"{mk}_obs_q\"], qm1[f\"{mk}_his_q\"]))\n        da = dsm[\"pr\"].sel(time=dsm[\"pr\"].time.dt.month == month)\n        n  = min(len(raw), len(obs5), len(da.time))\n        mlp = da.values[:n, WIN5[\"ii\"], WIN5[\"jj\"]]\n        raw, bias, obs = raw[:n], bias[:n], obs5[:n]\n        yrs = dates.year.values[:n]\n        preds = {\"raw\": raw, \"bias\": bias, \"mlp\": mlp}\n\n        # pooled daily (all cells × all days) — valid where both finite & ≥0\n        for s in preds:\n            o, p = obs.ravel(), preds[s].ravel()\n            v = np.isfinite(o) & np.isfinite(p) & (o >= 0) & (p >= 0)\n            daily[s][\"o\"].append(o[v]); daily[s][\"p\"].append(p[v])\n            if month in (6, 7, 8, 9):\n                jjas[s][\"o\"].append(o[v]); jjas[s][\"p\"].append(p[v])\n\n        # monthly TOTALS per cell-year (sum of daily over that month) → pooled\n        for yr in np.unique(yrs):\n            sel = yrs == yr\n            o_tot = np.nansum(obs[sel], axis=0)                            # (n5,)\n            for s in preds:\n                p_tot = np.nansum(preds[s][sel], axis=0)\n                vv = np.isfinite(o_tot) & np.isfinite(p_tot)\n                mtot[s][\"o\"].append(o_tot[vv]); mtot[s][\"p\"].append(p_tot[vv])\n\n        # climatology accumulators (sum of daily, all years)\n        clim_sum[\"obs\"] += np.nansum(obs, axis=0); clim_cnt += obs.shape[0]\n        for s in preds: clim_sum[s] += np.nansum(preds[s], axis=0)\n        # per-month region-mean (for annual cycle corr)\n        mon_mean[\"obs\"][month-1] += np.nanmean(obs); mon_cnt[month-1] += 1\n        for s in preds: mon_mean[s][month-1] += np.nanmean(preds[s])\n    dsm.close()\n    for s in clim_sum: clim_sum[s] /= max(clim_cnt, 1)                     # mean daily per cell\n    for s in mon_mean: mon_mean[s] /= np.where(mon_cnt == 0, 1, mon_cnt)\n    return daily, jjas, mtot, clim_sum, mon_mean\n\nprint(\"Collecting fields for RAW / BIAS / MLP vs 0.05° CHIRPS …\", flush=True)\ndaily, jjas, mtot, clim, mon = _collect(EVAL_YEARS, EVAL_NC)\n\n# ── assemble the metric table ────────────────────────────────────────\ndef cat(d, s): return np.concatenate(d[s][\"o\"]), np.concatenate(d[s][\"p\"])\nrows = [\"MAE (daily)\", \"MSE (daily)\", \"RMSE (daily)\", \"R² (daily)\", \"KGE (daily)\",\n        \"RMSE (monthly total)\", \"KGE (monthly total)\",\n        \"KGE (JJAS daily)\", \"R² (JJAS daily)\",\n        \"Spatial climatology corr\", \"Annual cycle corr\"]\ntable = {}\nfor s in [\"raw\", \"bias\", \"mlp\"]:\n    od, pd_ = cat(daily, s)\n    om, pm  = cat(mtot, s)\n    oj, pj  = cat(jjas, s)\n    table[s] = [\n        _mae(od, pd_), _mse(od, pd_), _rmse(od, pd_), _r2(od, pd_), _kge(od, pd_),\n        _rmse(om, pm), _kge(om, pm),\n        _kge(oj, pj), _r2(oj, pj),\n        _corr(clim[\"obs\"], clim[s]),\n        _corr(mon[\"obs\"], mon[s]),\n    ]\n\nimport pandas as pd\ndf = pd.DataFrame(table, index=rows)\ndf.columns = [\"Raw GCM\", \"Bias-corrected\", \"MLP downscaled\"]\npd.set_option(\"display.float_format\", lambda v: f\"{v:.4f}\")\nprint(f\"\\n================  METRICS  (test {EVAL_YEARS.start}-{EVAL_YEARS.stop-1})  ================\")\nprint(df.to_string())\ndf.to_csv(f\"{OUT_DIR}/metrics_table.csv\")\nprint(f\"\\n✅ saved → {OUT_DIR}/metrics_table.csv\")\n\n# ── BAR CHARTS: per-month RMSE & R² (daily, per stage) ───────────────\ndef _per_month(years, mlp_nc):\n    dsm = xr.open_dataset(mlp_nc); pm = {}\n    for month in range(1, 13):\n        g1, doy, dates = load_month(\"gcm1\", years, month)\n        obs5, _, _     = load_month(\"chr5\", years, month)\n        if g1 is None or obs5 is None: continue\n        mk = f\"m{month:02d}\"\n        raw  = bc1_to_0